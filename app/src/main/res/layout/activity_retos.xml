<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="140dp"
                android:background="@drawable/rounded_header"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:paddingBottom="30dp">

                <TextView
                    android:id="@+id/main_textview_tema"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:gravity="center"
                    android:text="Cargando tema..."
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/main_textview_pregunta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="20dp"
                    android:gravity="center"
                    android:text="Cargando pregunta..."
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/code_scroll_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/background_code"
                android:elevation="4dp"
                android:scrollbars="horizontal">

                <TextView
                    android:id="@+id/main_code_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:padding="16dp"
                    android:scrollHorizontally="true"
                    android:text="// Cargando codigo..."
                    android:textSize="14sp" />
            </HorizontalScrollView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/main_button_opt1"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:minHeight="60dp"
                android:text="Opción 1"
                android:textColor="@android:color/black"
                app:backgroundTint="@android:color/white"
                app:strokeColor="#BDBDBD"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/main_button_opt2"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="12dp"
                android:minHeight="60dp"
                android:text="Opción 2"
                android:textColor="@android:color/black"
                app:backgroundTint="@android:color/white"
                app:strokeColor="#BDBDBD"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/main_button_opt3"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="12dp"
                android:minHeight="60dp"
                android:text="Opción 3"
                android:textColor="@android:color/black"
                app:backgroundTint="@android:color/white"
                app:strokeColor="#BDBDBD"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/main_button_opt4"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:minHeight="60dp"
                android:text="Opción 4"
                android:textColor="@android:color/black"
                app:backgroundTint="@android:color/white"
                app:strokeColor="#BDBDBD"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/main_button_generar"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:backgroundTint="#5C6BC0"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="SIGUIENTE"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="0dp" />

</LinearLayout>